<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="FastCUA"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        Topmost="True"
        ShowInTaskbar="False"
        ShowActivated="False"
        Width="320" Height="52"
        WindowStartupLocation="Manual">
  <Border CornerRadius="12" Background="#FFFFFF" Padding="8,10">
    <Grid>
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*"/>
        <ColumnDefinition Width="Auto"/>
      </Grid.ColumnDefinitions>
      <TextBox x:Name="InputBox"
               Background="#F5F5F7" Foreground="#1D1D1F"
               BorderBrush="#E5E5EA" BorderThickness="1"
               Padding="8,4" FontSize="12" Height="28"
               VerticalContentAlignment="Center"/>
      <Button x:Name="StopBtn" Grid.Column="1"
              Content="Stop" FontSize="12" Width="44" Height="28"
              Background="#E5E5EA" Foreground="#FF3B30"
              BorderBrush="Transparent" BorderThickness="0" Cursor="Hand" Margin="6,0,0,0"/>
    </Grid>
  </Border>
</Window>
