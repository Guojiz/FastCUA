<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="FastCUA" WindowStyle="None" AllowsTransparency="True"
        Background="Transparent" ResizeMode="NoResize" Topmost="True"
        ShowInTaskbar="False" ShowActivated="False" Width="410" Height="68"
        WindowStartupLocation="Manual">
  <Border x:Name="IslandRoot" CornerRadius="23" Padding="14,8"
          Background="#B20B0F19" BorderBrush="#8063D5FF" BorderThickness="1.2"
          Cursor="Hand">
    <Border.Effect><DropShadowEffect Color="#6600B8FF" BlurRadius="24" ShadowDepth="2" Opacity=".62"/></Border.Effect>
    <Grid>
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="Auto"/>
      </Grid.RowDefinitions>
      <Grid x:Name="CompactPanel" Grid.Row="0" Height="50" VerticalAlignment="Center">
        <Grid.ColumnDefinitions><ColumnDefinition Width="18"/><ColumnDefinition Width="*"/><ColumnDefinition Width="18"/></Grid.ColumnDefinitions>
        <Ellipse x:Name="StateDot" Width="8" Height="8" Fill="#38D996" VerticalAlignment="Center" HorizontalAlignment="Left"/>
        <StackPanel Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center">
          <TextBlock x:Name="StatusText" Text="FastCUA is using your computer" TextAlignment="Center"
                     Foreground="#F7FAFF" FontSize="14.5" FontWeight="SemiBold"/>
          <TextBlock x:Name="ShortcutText" Text="F7 settings  |  F8 pause  |  F9 interject  |  F10 exit" TextAlignment="Center"
                     Foreground="#B7C2D8" FontSize="10.5" Margin="0,2,0,0"/>
        </StackPanel>
      </Grid>

      <StackPanel x:Name="ExpandedPanel" Grid.Row="1" Visibility="Collapsed" Margin="0,10,0,0">
        <TextBlock x:Name="ActionText" Text="Desktop control is active" TextAlignment="Center"
                   Foreground="#C5CEE1" FontSize="12" TextTrimming="CharacterEllipsis"/>
        <Border x:Name="ApprovalPanel" Background="#12FFFFFF" CornerRadius="12" Padding="11,9" Margin="0,10,0,0" Visibility="Collapsed">
          <StackPanel>
            <TextBlock x:Name="AppText" Text="Unknown application" Foreground="#F8D782" FontSize="11" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
            <WrapPanel Orientation="Horizontal" Margin="0,8,0,0">
              <Button x:Name="AllowOnceBtn" Content="1 · Allow once" FontSize="10.5" Padding="10,5" Margin="0,0,6,6" Foreground="#08121D" Background="#F8D782" BorderBrush="Transparent" Cursor="Hand" ToolTip="Keyboard: 1"/>
              <Button x:Name="TrustBtn" Content="2 · Always approve" FontSize="10.5" Padding="10,5" Margin="0,0,6,6" Foreground="#F6F8FF" Background="#27FFFFFF" BorderBrush="#35FFFFFF" Cursor="Hand" ToolTip="Keyboard: 2 — whitelist this app forever"/>
              <Button x:Name="FullAccessBtn" Content="3 · Full access" FontSize="10.5" Padding="10,5" Margin="0,0,6,6" Foreground="#FFD6F0" Background="#28FF70C6" BorderBrush="#55FF70C6" Cursor="Hand" ToolTip="Keyboard: 3 — allow all apps without further prompts"/>
              <Button x:Name="DenyBtn" Content="4 · Deny" FontSize="10.5" Padding="10,5" Margin="0,0,0,6" Foreground="#FFB0B9" Background="#18FF6E7F" BorderBrush="#33FF6E7F" Cursor="Hand" ToolTip="Keyboard: 4"/>
            </WrapPanel>
          </StackPanel>
        </Border>
        <Grid x:Name="InterjectPanel" Margin="0,10,0,0">
          <Grid.RowDefinitions><RowDefinition Height="38"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
          <TextBox x:Name="InputBox" Background="#24FFFFFF" Foreground="#F5F8FF" BorderBrush="#50FFFFFF" BorderThickness="1"
                   Padding="13,7" FontSize="12.5" Height="38" VerticalContentAlignment="Center" ToolTip="Interject and redirect the agent"/>
          <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,9,0,0">
            <Button x:Name="SettingsBtn" Content="Settings" FontSize="10.5" Padding="11,5" Foreground="#DDE7F7" Background="#20FFFFFF" BorderBrush="#35FFFFFF" Cursor="Hand"/>
            <Button x:Name="PauseBtn" Content="Pause" FontSize="10.5" Padding="11,5" Margin="7,0,0,0" Foreground="#F5F8FF" Background="#26FFFFFF" BorderBrush="#3FFFFFFF" Cursor="Hand"/>
            <Button x:Name="ResumeBtn" Content="Resume" FontSize="10.5" Padding="11,5" Margin="7,0,0,0" Foreground="#08121D" Background="#8AF8FAFF" BorderBrush="Transparent" Cursor="Hand" Visibility="Collapsed"/>
            <Button x:Name="StopBtn" Content="Stop task" FontSize="10.5" Padding="11,5" Margin="7,0,0,0" Foreground="#FFB0B9" Background="#18FF6E7F" BorderBrush="#33FF6E7F" Cursor="Hand"/>
            <Button x:Name="ExitBtn" Content="Exit" FontSize="10.5" Padding="11,5" Margin="7,0,0,0" Foreground="#FFD6DA" Background="#12FFFFFF" BorderBrush="#33FFFFFF" Cursor="Hand"/>
          </StackPanel>
        </Grid>
      </StackPanel>
    </Grid>
  </Border>
</Window>
