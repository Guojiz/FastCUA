<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="FastCUA"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        Topmost="True"
        ShowInTaskbar="False"
        ShowActivated="False"
        Width="300" Height="100"
        WindowStartupLocation="Manual">
  <!-- Semi-transparent dark card -->
  <Border CornerRadius="10" Background="#CC1C1C1E" Padding="14,10">
    <Grid>
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="Auto"/>
      </Grid.RowDefinitions>

      <!-- Row 0: title -->
      <TextBlock Grid.Row="0"
                 Text="TITLE_PLACEHOLDER"
                 Foreground="#E0E0E0" FontSize="11.5"
                 FontWeight="Medium"
                 TextTrimming="CharacterEllipsis"
                 Margin="0,0,0,4"/>

      <!-- Row 1: subtitle -->
      <TextBlock Grid.Row="1"
                 Text="SUBTITLE_PLACEHOLDER"
                 Foreground="#888888" FontSize="10"
                 Margin="0,0,0,8"/>

      <!-- Row 2: interjection input + stop button -->
      <Grid Grid.Row="2">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>
        <TextBox x:Name="InputBox"
                 Background="#FFFFFF" Foreground="#1D1D1F"
                 BorderBrush="Transparent" BorderThickness="0"
                 Padding="10,5" FontSize="11.5"
                 Height="26"
                 VerticalContentAlignment="Center">
          <TextBox.Resources>
            <Style TargetType="{x:Type Border}">
              <Setter Property="CornerRadius" Value="6"/>
            </Style>
          </TextBox.Resources>
        </TextBox>
        <Button x:Name="StopBtn" Grid.Column="1"
                Content="Stop" FontSize="11"
                Width="44" Height="26"
                Foreground="#E0E0E0"
                Background="#33FFFFFF"
                BorderBrush="Transparent" BorderThickness="0"
                Cursor="Hand" Margin="6,0,0,0">
          <Button.Resources>
            <Style TargetType="{x:Type Border}">
              <Setter Property="CornerRadius" Value="6"/>
            </Style>
          </Button.Resources>
        </Button>
      </Grid>
    </Grid>
  </Border>
</Window>
